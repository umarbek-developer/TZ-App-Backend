# ===== MAIN SETTINGS =====
DEBUG=1
# Signs both Django sessions and the JWTs. Must be long and random — a short key
# produces weak HMAC signatures that are cheap to brute-force. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=replace-me-with-a-generated-50-char-key
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://localhost:3000
BASE_URL_LINK=http://127.0.0.1:8000/api/v1/user/auth/register/confirmations/


# ===== DATABASE =====
# PostgreSQL is required. DB_TYPE must be "psql" — there is no sqlite fallback.
# Leave DB_HOST empty to connect over the local Unix socket (peer auth, no
# password); set it to a hostname when using TCP, and then DB_PASSWORD is required.
DB_TYPE=psql
DB_NAME=tz_app
DB_USER=postgres
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# ===== CELERY =====
BASE_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_CHANNEL_ID=

# ===== REDIS =====
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# ===== Email =====
EMAIL_HOST=
EMAIL_PASSWORD=
